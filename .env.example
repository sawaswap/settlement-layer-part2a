# SawaSwap Operator Console — environment configuration
#
# The Console is a no-backend SPA (Agreement C.5.f): every value here is compiled
# into the browser bundle and is therefore PUBLIC. None of these are secrets.
# Chain-/asset-agnosticism (C.2 Screen 4, FIS Chain-Agnostic Adaptation Notes)
# lives here: porting to another network or asset is an env change, not a code change.

# --- Application ---
VITE_APP_NAME="SawaSwap Operator Console"

# --- Chain (Base Sepolia by default) ---
VITE_CHAIN_ID=84532
VITE_CHAIN_NAME="Base Sepolia"
VITE_RPC_URL="https://sepolia.base.org"
VITE_EXPLORER_URL="https://sepolia.basescan.org"
VITE_EXPLORER_NAME="Basescan"
VITE_NATIVE_SYMBOL="ETH"

# --- Contracts (Part 1 M3 deployment of record, Base Sepolia) ---
VITE_SETTLEMENT_ADDRESS="0x9645827808E25b4e19B1B8A05B075606dfF86331"
VITE_MOCKDRP_ADDRESS="0x9Fdb4DAE76C0D481b3fa46A0131D95e4000Ef769"

# --- Escrow asset ---
VITE_USDC_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"
VITE_USDC_SYMBOL="USDC"
VITE_USDC_DECIMALS=6

# --- WalletConnect (optional) ---
# Leave blank to run with injected/Coinbase connectors only. Production projectId
# is held by the Client per Agreement E.2. Get one at https://cloud.reown.com.
VITE_WALLETCONNECT_PROJECT_ID=""
